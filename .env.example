# NotionMCP Environment Configuration
# Austrian Efficiency Setup for Notion Workspace Management

# ========================================
# REQUIRED - Notion Authentication (choose one)
# ========================================

# Option A: Internal integration token (bot-scoped)
# Get from: https://www.notion.so/my-integrations
# Click "New integration" -> Give it a name -> Copy the token
NOTION_TOKEN=secret_your_notion_integration_token_here

# Option B: Personal Access Token (user-scoped, uses your permissions)
# Get from: https://www.notion.so/profile/integrations -> "Personal access tokens"
# NOTE: PAT takes priority over NOTION_TOKEN if both are set
NOTION_PAT=ntn_your_personal_access_token_here

# Notion API version (latest: 2026-03-11)
NOTION_VERSION=2026-03-11

# ========================================
# OPTIONAL - LLM for AI Summary
# ========================================

# URL of an OpenAI-compatible LLM API (e.g. Ollama, LM Studio, OpenAI)
# When set, generate_ai_summary calls this API instead of using mock.
# Example: http://localhost:11434/v1/chat/completions
LLM_API_URL=

# API key for the LLM endpoint (default: "ollama")
LLM_API_KEY=ollama

# Model name (default: "llama3.2")
LLM_MODEL=llama3.2

# ========================================
# OPTIONAL - Webhook Configuration
# ========================================

# Public URL where Notion sends webhook events.
# Set this to your public endpoint (e.g. https://your-ngrok.ngrok.dev)
# Notion webhooks are configured in the Notion UI at:
#   https://www.notion.so/developers/connections
NOTION_WEBHOOK_URL=

# ========================================
# OPTIONAL - Notion CLI (ntn) for Workers
# ========================================

# Path to ntn binary (default: "ntn" — assumed on PATH)
NTN_BIN=ntn

# ========================================
# OPTIONAL - Server Configuration
# ========================================

# Comma-separated URLs of remote MCP servers to bridge
MCP_BRIDGE_URLS=

# MCP server display name
MCP_SERVER_NAME="Notion Workspace Management MCP 🗃️"

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Server environment (development, production, academic)
ENVIRONMENT=development

# ========================================
# OPTIONAL - Performance Tuning
# ========================================

# Request timeout in seconds (Austrian efficiency)
NOTION_TIMEOUT=30

# Maximum results per page (budget awareness)
MAX_RESULTS_PER_PAGE=100

# Enable response caching for better performance
ENABLE_CACHING=true

# Cache duration in seconds
CACHE_DURATION=300

# Maximum concurrent requests
MAX_CONCURRENT_REQUESTS=5

# ========================================
# OPTIONAL - Austrian/Vienna Context
# ========================================

# Timezone setting (European efficiency)
TIMEZONE=Europe/Vienna

# Date format (Austrian standard)
DATE_FORMAT=DD.MM.YYYY

# Primary language (German/English)
LANGUAGE=de

# Currency for budget tracking
CURRENCY=EUR

# Monthly budget in EUR (~€100/month consideration)
MONTHLY_BUDGET_EUR=100

# ========================================
# OPTIONAL - Feature Flags
# ========================================

# Enable Notion AI features (when available)
ENABLE_AI_FEATURES=true

# Enable webhook support for automations
ENABLE_WEBHOOKS=true

# Enable bulk operations for efficiency
ENABLE_BULK_OPERATIONS=true

# Enable export functionality
ENABLE_EXPORT=true

# Enable collaboration features
ENABLE_COLLABORATION=true

# ========================================
# OPTIONAL - Academic Research Features
# ========================================

# Enable academic templates and workflows
ENABLE_ACADEMIC_MODE=true

# Default citation format (APA, MLA, Chicago, IEEE)
DEFAULT_CITATION_FORMAT=APA

# Enable bibliography management
ENABLE_BIBLIOGRAPHY=true

# ========================================
# OPTIONAL - Weeb Features 🎌
# ========================================

# Enable Japanese character support
ENABLE_JAPANESE_SUPPORT=true

# Enable anime/manga database templates
ENABLE_ANIME_TEMPLATES=true

# Enable language learning tools
ENABLE_LANGUAGE_LEARNING=true

# ========================================
# OPTIONAL - Advanced Configuration
# ========================================

# Custom webhook endpoint for notifications
WEBHOOK_URL=

# External API keys for integrations
GITHUB_TOKEN=
JIRA_API_KEY=
GOOGLE_SHEETS_CREDENTIALS=

# Database connection for local caching (optional)
DATABASE_URL=

# Redis URL for caching (optional)
REDIS_URL=

# ========================================
# OPTIONAL - Debugging and Development
# ========================================

# Enable debug mode (more verbose logging)
DEBUG_MODE=false

# Enable request/response logging
LOG_API_CALLS=false

# Enable performance monitoring
ENABLE_MONITORING=true

# Test workspace ID for development
TEST_WORKSPACE_ID=

# Mock mode for testing without real API calls
MOCK_MODE=false

# ========================================
# Security Notes (Austrian Directness)
# ========================================

# 1. NEVER commit this file with real tokens to git!
# 2. Keep your NOTION_TOKEN secure and rotate it regularly
# 3. Use different tokens for development and production
# 4. Grant minimal permissions to your Notion integration
# 5. Monitor API usage to stay within budget limits

# ========================================
# Setup Instructions
# ========================================

# 1. Copy this file to .env (without .example)
# 2. Replace placeholder values with your actual settings
# 3. Get your Notion token from https://www.notion.so/my-integrations
# 4. Add your integration to the workspaces you want to access
# 5. Run: pip install -r requirements.txt
# 6. Start server: python server.py

# Austrian Efficiency Tip:
# Only set the variables you actually need - defaults are optimized for Vienna workflows! 🇦🇹
