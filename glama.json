{
  "$schema": "https://glama.ai/mcp/schemas/server.json",
  "mcpServers": {
    "notion-mcp": {
      "command": "python",
      "args": [
        "server.py"
      ],
      "env": {
        "PYTHONPATH": "${workspaceFolder}/notion-mcp",
        "PYTHONUNBUFFERED": "1"
      },
      "description": "FastMCP 3.1 compatible MCP server for comprehensive Notion workspace management and RAG-powered semantic discovery. 21 tools including pages, databases, RAG synchronization, and semantic search.",
      "capabilities": {
        "tools": {
          "enabled": true
        },
        "resources": {
          "enabled": false
        },
        "prompts": {
          "enabled": true
        }
      },
      "timeout": {
        "initialize": 30000,
        "message": 60000
      },
      "metadata": {
        "version": "1.1.0",
        "author": "Sandra Schi",
        "homepage": "https://github.com/sandraschi/notion-mcp",
        "license": "MIT",
        "tags": [
          "notion",
          "rag",
          "lancedb",
          "vector-search",
          "semantic-search",
          "workspace",
          "pages",
          "databases",
          "fastmcp",
          "productivity",
          "mcp-server"
        ],
        "categories": [
          "productivity",
          "search",
          "knowledge-management",
          "automation"
        ]
      }
    }
  },
  "maintainers": [
    "sandraschi"
  ],
  "name": "notion-mcp",
  "description": "FastMCP 3.1 compatible MCP server for comprehensive Notion workspace management and RAG-powered semantic discovery. 21 tools including pages, databases, RAG synchronization, and semantic search. SOTA 2026.",
  "type": "mcp_server",
  "status": "production",
  "framework": "FastMCP 3.1",
  "tools": 21,
  "transport": [
    "stdio"
  ],
  "keywords": [
    "notion",
    "workspace",
    "pages",
    "databases",
    "collaboration",
    "automation",
    "fastmcp",
    "productivity",
    "mcp-server"
  ],
  "features": {
    "page_management": {
      "enabled": true,
      "operations": [
        "create",
        "read",
        "update",
        "delete",
        "search"
      ]
    },
    "database_operations": {
      "enabled": true,
      "features": [
        "query",
        "create",
        "modify",
        "filter",
        "sort"
      ]
    },
    "collaboration": {
      "enabled": true,
      "features": [
        "sharing",
        "comments",
        "permissions"
      ]
    },
    "automation": {
      "enabled": true,
      "capabilities": [
        "triggers",
        "actions",
        "workflows"
      ]
    }
  }
}